# ───────────────────────────────────────────────
# Trading Bot — Variables de Entorno
# Copia este archivo como .env y edita los valores
# ───────────────────────────────────────────────

# ── IBKR Connection ──────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497          # 7497 = Paper Trading | 7496 = Real Trading
IBKR_CLIENT_ID=1
PAPER_TRADING=true      # ¡Cambia a false solo cuando estés listo para real!

# ── Servidor ─────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── SEGURIDAD - CAMBIA ESTO ──────────────────────
# Esta clave debe coincidir con el campo "secret" en tus alertas de TradingView
WEBHOOK_SECRET=CAMBIA_ESTA_CLAVE_SECRETA_123

# ── Gestión de Riesgo (valores por defecto) ───────
RISK_PER_TRADE_PCT=1.0        # % del capital por trade
MAX_DAILY_LOSS_PCT=5.0        # Bot se para si alcanza esta pérdida
MAX_OPEN_POSITIONS=5          # Max trades simultáneos
DEFAULT_STOP_LOSS_PCT=2.0     # Stop Loss automático
DEFAULT_TAKE_PROFIT_PCT=4.0   # Take Profit automático
MAX_POSITION_SIZE_PCT=20.0    # Max % del capital en una sola posición

# ── Logging ──────────────────────────────────────
LOG_LEVEL=INFO
